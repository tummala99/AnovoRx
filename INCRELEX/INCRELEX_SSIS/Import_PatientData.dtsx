          SQLTask:Connection="{E787FC3B-BFD1-4937-89E3-CE831CFCBCF4}"
          SQLTask:SqlStatementSource="&#x9;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID('dbo.Staging_ImportFileHeader') AND type = N'U')&#xA;&#x9;BEGIN&#xA;&#xA;&#x9;&#x9;CREATE TABLE [dbo].[Staging_ImportFileHeader](&#xA;&#x9;&#x9;&#x9;[Id] [INT] IDENTITY(1,1) NOT NULL,&#xA;&#x9;&#x9;&#x9;[FileName] VARCHAR(500),&#xA;&#x9;&#x9;&#x9;[ImportHeader] [VARCHAR](MAX) NULL,&#xA;&#x9;&#x9;&#x9;[ImportDate] DATETIME default GETDATE(),&#xA;&#x9;&#x9;&#x9;[IsProcessed] BIT default 0&#xA;&#x9;&#x9;) ON  [PRIMARY]&#xA;&#x9;END &#xA;&#x9;GO&#xA;&#xA;&#x9;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID('dbo.Staging_ImportFileData') AND type = N'U')&#xA;&#x9;BEGIN&#xA;&#xA;&#x9;&#x9;CREATE TABLE [dbo].[Staging_ImportFileData](&#xA;&#x9;&#x9;&#x9;[Id] [INT] IDENTITY(1,1) NOT NULL,&#xA;&#x9;&#x9;&#x9;[FileHeaderId] VARCHAR(500),&#xA;&#x9;&#x9;&#x9;[ImportData] [VARCHAR](MAX) NULL&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;) ON  [PRIMARY]&#xA;&#x9;END &#xA;&#x9;GO&#xA;&#xA;&#x9;IF NOT EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID('dbo.Staging_TempResults') AND type = N'U')&#xA;&#x9;BEGIN&#xA;&#xA;&#x9;&#x9;CREATE TABLE [dbo].[Staging_TempResults](&#xA;&#x9;&#x9;&#x9;[HeaderRowId] [INT] NOT NULL,&#xA;&#x9;&#x9;&#x9;[ColumnNames] VARCHAR(500),&#xA;&#x9;&#x9;&#x9;[DataItem] [VARCHAR](MAX) NULL,&#xA;&#x9;&#x9;&#x9;DataRowId INT,&#xA;&#x9;&#x9;&#x9;DataItemId INT&#xA;&#xA;&#x9;&#x9;) ON  [PRIMARY]&#xA;&#x9;END &#xA;&#x9;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
